git ls-files -- '*/bin/*' '*/obj/*' '*/temp/*'# add .gitignore
git add .gitignore

# remove already-tracked bin/obj/temp files
git ls-files -- '*/bin/*','*/obj/*','*/temp/*' | ForEach-Object { git rm --cached -- $_ }

# commit and push
git commit -m "Add .gitignore and remove build/temp outputs from repository"
git push# Visual Studio / .NET
